{
  "name": "@forloop-cc/forloop-cli",
  "version": "0.2.9",
  "description": "Command-line interface for the ForLoop AI development platform",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/forloop-cc/forloop-cli#readme",
  "bugs": {
    "url": "https://github.com/forloop-cc/forloop-cli/issues"
  },
  "keywords": [
    "forloop",
    "cli",
    "ai",
    "sprint",
    "agile"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forloop-cc/forloop-cli.git"
  },
  "bin": {
    "forloop": "dist/forloop"
  },
  "files": [
    "dist/",
    "install.sh",
    "README.md",
    "ERRORS.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs",
    "dev": "npx tsx src/main.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@forloop-cc/forloop-opencode-plugin-planner": "^2.2.7",
    "@opencode-ai/plugin": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "esbuild": "^0.25.12",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
